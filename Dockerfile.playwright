FROM mcr.microsoft.com/playwright:v1.56.1-jammy

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy test files and config
COPY e2e ./e2e
COPY playwright.config.ts ./
COPY tsconfig.json ./

# Copy shared schema for type definitions
COPY shared ./shared

# Set environment
ENV CI=true

# Run tests
CMD ["npm", "run", "test:e2e"]
