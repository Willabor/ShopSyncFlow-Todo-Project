{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --external:./vite --bundle --format=esm --outdir=dist && esbuild server/vite.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:run": "tsx server/migrate.ts",
    "migrate:category": "tsx server/scripts/category-to-tags-migration.ts",
    "migrate:categories": "tsx scripts/migrate-categories.ts",
    "migrate:categories:dry-run": "tsx scripts/migrate-categories.ts --dry-run",
    "migrate:categories:rollback": "tsx scripts/migrate-categories.ts --rollback",
    "test": "vitest",
    "test:server": "vitest --config vitest.config.server.ts",
    "test:server:watch": "vitest --config vitest.config.server.ts --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:docker": "docker-compose -f docker-compose.test.yml up --build",
    "test:e2e:docker:report": "docker-compose -f docker-compose.test.yml up --build && npm run test:e2e:show-report",
    "test:e2e:show-report": "npx playwright show-report",
    "test:google-ads": "tsx scripts/test-google-ads.ts",
    "auth:google-ads": "tsx scripts/get-google-ads-token.ts",
    "auth:google-ads:simple": "tsx scripts/get-google-ads-token-simple.ts"
  },
