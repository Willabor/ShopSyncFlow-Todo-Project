# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# ============================================================================
# Server Configuration
# ============================================================================
PORT=5000
NODE_ENV=development
SESSION_SECRET=your_session_secret_here

# ============================================================================
# API Key Encryption
# ============================================================================
# Secret key for encrypting API keys stored in the database (e.g., per-tenant Shopify tokens)
# REQUIRED for secure API key storage. Uses AES-256-GCM authenticated encryption.
#
# Generate a new key with one of these commands:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# The key must be exactly 64 hex characters (32 bytes).
# IMPORTANT: Keep this secret! If lost, encrypted API keys cannot be recovered.
# IMPORTANT: Never commit real keys to version control.
API_KEY_ENCRYPTION_SECRET=your_64_char_hex_key_here_generated_with_openssl_rand_hex_32

# ============================================================================
# Shopify Integration
# ============================================================================
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# ============================================================================
# Phase 1: Headless Browser Scraping (NEW)
# ============================================================================
# Enable/disable headless browser fallback for JavaScript-heavy sites
SCRAPER_HEADLESS_ENABLED=1

# Maximum number of concurrent Puppeteer browser instances (prevents memory overload)
# Recommended: 3-5 depending on server RAM (each browser uses ~150-200MB)
SCRAPER_MAX_CONCURRENT_BROWSERS=3

# Timeout for headless page loads (milliseconds)
# Increase for slow-loading sites, decrease to fail faster
SCRAPER_HEADLESS_TIMEOUT=30000

# ============================================================================
# Ethical Scraping Configuration (NEW)
# ============================================================================
# Contact email to include in User-Agent string (allows site owners to contact you)
SCRAPER_USER_AGENT_CONTACT=will@nexusclothing.com

# Enforce robots.txt compliance (1 = enforce, 0 = skip checks)
# IMPORTANT: Keep this as 1 for ethical/legal compliance
SCRAPER_RESPECT_ROBOTS_TXT=1

# ============================================================================
# Polite Fetching (Existing)
# ============================================================================
# Minimum delay between HTTP requests (milliseconds)
# Prevents rate limiting and server overload
SCRAPER_MIN_DELAY_MS=2000

# Maximum delay with random jitter (milliseconds)
# Must be >= SCRAPER_MIN_DELAY_MS + 250
SCRAPER_MAX_DELAY_MS=5000

# Maximum number of retries for blocked requests (403, 429, 503)
SCRAPER_MAX_RETRIES=3

# Override delays specifically for generic (non-Shopify) scraper
# Useful for being extra polite to unknown sites
SCRAPER_GENERIC_MIN_DELAY_MS=2200
SCRAPER_GENERIC_MAX_DELAY_MS=6000

# ============================================================================
# AI Integration - Multi-Provider Support
# ============================================================================
# ShopSyncFlow supports multiple AI providers with BYOK (Bring Your Own Key).
# Tenants can configure their own keys in Settings > AI Settings.
# Platform defaults below are used for free tier tenants.

# Google Gemini (Default Provider)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (Optional - for BYOK or platform default)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic Claude (Optional)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Mistral AI (Optional)
# Get from: https://console.mistral.ai/
# MISTRAL_API_KEY=...

# ============================================================================
# Phase 2: AI-Powered Extraction (IMPLEMENTED - Layer 3 Fallback)
# ============================================================================

# Enable/disable AI extraction fallback (requires Gemini API key)
# Set to 1 to enable, 0 to disable
# AI extraction is used when Shopify and Generic scrapers fail
# Uses Gemini 2.0 Flash (free tier: 1,500 requests/day)
SCRAPER_AI_ENABLED=1

# AI model to use (gemini-2.0-flash = fastest, free tier)
# SCRAPER_AI_MODEL=gemini-2.0-flash

# Cache AI results longer than other methods (days)
# AI extraction uses API quota, so cache longer
# SCRAPER_AI_CACHE_DAYS=30

# Daily budget limit for AI extraction (USD)
# Optional: Set a safety limit to prevent cost overruns
# SCRAPER_AI_MAX_COST_PER_DAY=10.00

# ============================================================================
# Optional: Async Job Queue (Future - Not Yet Implemented)
# ============================================================================
# Redis configuration for BullMQ job queue
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Maximum concurrent enrichment jobs
# SCRAPER_MAX_CONCURRENT_JOBS=5

# ============================================================================
# Phase 3: Puppeteer Microservice (Microservice Architecture)
# ============================================================================
# Standalone Puppeteer service for JavaScript-heavy SPAs and size chart extraction
# Service runs on port 7000 with advanced scraping capabilities:
# - Network request sniffing for size chart URLs
# - Modal interaction detection
# - Global size guide page discovery
# - Multi-category size chart extraction (men/women/kids)
PUPPETEER_SERVICE_ENABLED=1
PUPPETEER_SERVICE_URL=http://localhost:7000
